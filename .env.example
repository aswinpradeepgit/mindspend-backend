# Copy to .env and fill in. NEVER commit the real .env.

# Supabase Postgres connection (Dashboard → Connect → ORMs/Session pooler).
# Use the SQLAlchemy asyncpg scheme and URL-encode special chars in the password.
# Session pooler (port 5432) is recommended — it's IPv4 and works on Render.
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Supabase project URL (Settings → Data API, or https://<project-ref>.supabase.co).
# Used to verify asymmetric (JWT Signing Keys) access tokens via JWKS.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Legacy JWT secret (Settings → JWT Keys → Legacy JWT Secret → Copy).
# Used to verify HS256 access tokens. Set both this and SUPABASE_URL.
SUPABASE_JWT_SECRET=your-legacy-jwt-secret

# Comma-separated allowed frontend origins.
# Add your Vercel URL and Capacitor origins when you ship: capacitor://localhost,http://localhost
ALLOWED_ORIGINS=http://localhost:3000

ENV=development
